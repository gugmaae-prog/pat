{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "es2022"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"]
    },
    "plugins": [{ "name": "next" }]
  },
  "include": [
    "next-env.d.ts",
    "app/**/*.ts",
    "app/**/*.tsx",
    "app/**/*.js",
    "app/**/*.jsx",
    "components/**/*.ts",
    "components/**/*.tsx",
    "components/**/*.js",
    "components/**/*.jsx",
    "lib/**/*.ts",
    "lib/**/*.tsx",
    "lib/**/*.js",
    "lib/**/*.jsx",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules", "supabase/**"]
}
